# Copy this file to `.env.prod` on VPS and fill real values.

# ---------- Required secrets ----------
GOOGLE_API_KEY=replace_me
WAHA_API_KEY=replace_me
WAHA_DASHBOARD_PASSWORD=replace_me
WHATSAPP_SWAGGER_PASSWORD=replace_me
POSTGRES_PASSWORD=replace_me

# IMPORTANT: keep same DB name/user or adjust both DATABASE_URL + postgres env.
POSTGRES_DB=whatsapp_flows
POSTGRES_USER=flowbuilder
DATABASE_URL=postgresql://flowbuilder:replace_me@postgres:5432/whatsapp_flows

# ---------- Optional ----------
WAHA_SESSION=default
WAHA_INSTANCE_MAP={"default":{"url":"http://waha:3000","session":"default"}}
WAHA_DASHBOARD_USERNAME=admin
WHATSAPP_SWAGGER_USERNAME=admin

RQ_WORKER_DEFAULT_COUNT=1
RQ_WORKER_MIN_COUNT=1
RQ_WORKER_MAX_COUNT=16
RQ_WORKER_MANAGER_HEARTBEAT_TTL_SECONDS=15

RAG_GROUNDING_THRESHOLD=0.46
RAG_FINAL_CONTEXT_K=8
RAG_RETRIEVAL_CANDIDATES=22
RAG_REQUIRE_CITATIONS=false
CONVERSATION_MEMORY_SCOPE=client_workspace

# Host port mappings
SERVER_PORT=8000
FRONTEND_PORT=5172
WAHA_PORT=3000
