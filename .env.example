# ============================================
# Async RAG Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# Required: GOOGLE_API_KEY
# Optional: Everything else has defaults
# ============================================

# ===================
# REQUIRED - AI Model
# ===================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
# Direct chat model for /api/chat/respond
# DIRECT_CHAT_MODEL=gemini-2.5-flash
# DIRECT_CHAT_TEMPERATURE=0.3

# ===================
# OPTIONAL - Services
# ===================
# These have defaults in docker-compose.yml, only change if needed

# Redis/Valkey (defaults work for Docker)
# REDIS_HOST=valkey
# REDIS_PORT=6379
# Optional: cache repeated prompts per workspace (seconds, 0 disables)
# RAG_RESPONSE_CACHE_TTL_SECONDS=300
# Optional: dedupe repeated webhook delivery by message id (seconds, 0 disables)
# WEBHOOK_DEDUP_TTL_SECONDS=600

# Qdrant Vector Database (defaults work for Docker)
# QDRANT_URL=http://qdrant:6333

# FastAPI Server URL (used by worker to send WebSocket notifications)
# SERVER_URL=http://async_rag_server:8000

# RQ Worker Pool runtime scaling (Dashboard controlled)
# RQ_WORKER_DEFAULT_COUNT=1
# RQ_WORKER_MIN_COUNT=1
# RQ_WORKER_MAX_COUNT=16
# RQ_WORKER_DESIRED_KEY=rq:workers:desired_count
# RQ_WORKER_MANAGER_HEARTBEAT_KEY=rq:workers:manager:heartbeat
# RQ_WORKER_MANAGER_HEARTBEAT_TTL_SECONDS=15
# Flow runtime dashboard metrics window (minutes)
# FLOW_RUNTIME_WINDOW_MINUTES=15
# A running execution older than this is treated as stale (minutes)
# FLOW_RUNNING_STALE_MINUTES=5

# ===================
# OPTIONAL - WAHA (WhatsApp)
# ===================
# WAHA URL (defaults work for Docker)
# WAHA_URL=http://waha:3000

# WAHA API key for authentication
WAHA_API_KEY=Yahoo

# WhatsApp engine: NOWEB (default) or WEBJS
WHATSAPP_DEFAULT_ENGINE=NOWEB

# ===================
# OPTIONAL - System
# ===================
# Fix for macOS fork() issues with Python multiprocessing
OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Device-style client_id hash salt for /api/chat/respond
# CLIENT_ID_SALT=change-this-in-production

# Optional API key guard for public client chat endpoint.
# If set, clients must send header: X-Client-Api-Key
# CLIENT_CHAT_API_KEY=replace-with-long-random-secret
# Optional admin key for managing tenant client keys via /api/chat/keys.
# If unset, server falls back to CLIENT_CHAT_API_KEY for admin operations.
# CLIENT_CHAT_ADMIN_KEY=replace-with-admin-secret
# Salt for hashing tenant API keys in DB
# CLIENT_CHAT_API_KEY_SALT=replace-with-random-salt
# Default prompt style for client chat if request/key doesn't override
# CLIENT_CHAT_DEFAULT_PROMPT_TECHNIQUE=balanced
# Optional global daily limit per IP+system (0 disables, tenant key overrides)
# CLIENT_CHAT_DAILY_LIMIT_PER_DEVICE=0
